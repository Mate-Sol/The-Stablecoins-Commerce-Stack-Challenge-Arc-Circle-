# ─── MongoDB ────────────────────────────────────────────────────────────────
# Replace USERNAME, PASSWORD, CLUSTER, and DB_NAME. Make sure the database
# name (last path segment before `?`) matches the DB you actually use.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DB_NAME?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────
# Rotate per environment. Generate a fresh value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5050
# Production frontend origin (added to CORS allowlist). Local dev origins
# (localhost / 127.0.0.1) are always allowed automatically.
FRONTEND_URL=https://your-frontend.example.com

# ─── Solana ─────────────────────────────────────────────────────────────────
# Public devnet works for casual testing but is heavily rate-limited.
# For real use, get a free key from Helius / QuickNode / Triton:
#   https://devnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# Anchor program ID. Must match `declare_id!` in lib.rs AND the `address`
# field in server/idl/paymate_pool_v2.json.
PAYMATE_PROGRAM_ID=

# SPL Token mint representing "USDC-DF" (test USDC). The faucet at
# /faucet/usdc-df mints this token. Empty value disables the faucet
# AND breaks pool initialization.
USDC_DF_MINT_ADDRESS=

# Comma-separated allowlist of base58 pubkeys allowed to sign in to the
# on-chain admin portal. At least one entry required.
ONCHAIN_ADMIN_WALLETS=

# Mint authority keypair for USDC-DF, as a JSON byte array. DEVNET ONLY —
# this key has no power over real USDC on mainnet.
#   solana-keygen new --no-bip39-passphrase -o faucet.json
# then paste the file's contents (literal JSON array) here.
FAUCET_AUTHORITY_PRIVATE_KEY=

# Server-side fee-payer keypair (JSON byte array). The relay at /relay/submit
# uses this to cover SOL fees so end users never need SOL in their wallets.
# MUST be a different key than the faucet authority and any admin key.
# Fund it on devnet:  solana airdrop 2 <pubkey> --url devnet
FEE_PAYER_PRIVATE_KEY=

# Per-wallet daily quota of relayed transactions.
RELAY_DAILY_QUOTA=50
