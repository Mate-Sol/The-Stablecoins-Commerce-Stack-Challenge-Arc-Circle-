# Dependencies
node_modules/

# Builds
dist/
build/
out/

# Environment — NEVER commit any .env with secrets
.env
.env.*
!.env.example
!.env.production.example
# FE build-time env: only public (onchain addresses, RPC, API URL). Vite bakes
# these into the static bundle, so they cannot be secrets by definition.
!client/.env.production
!client-legacy/.env.production

# Kubernetes Secrets — contain live MONGODB_URI / private keys / JWT secret
*-secret.yaml
*-secret.yml

# Foundry
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/.forge-snapshots/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
logs/

# OS / editor
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Uploads (CRO-uploaded credit memos, etc. — local-fs fallback)
server/public/uploads/

# Test artifacts
coverage/
.nyc_output/

# Server-side uploads (never commit user-uploaded files)
server/public/paymate-files/uploads/*
!server/public/paymate-files/uploads/.gitkeep
