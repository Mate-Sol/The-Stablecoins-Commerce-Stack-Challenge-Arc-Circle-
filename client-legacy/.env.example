# ─── API ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5050

# ─── Deployed contract addresses ───────────────────────────────────────
# Populated by `contracts/script/Deploy.s.sol` — copy the values it prints
# into your .env. Leave blank until you deploy; the client tolerates
# missing addresses (buttons that need them just error visibly).
VITE_STABLECOIN_ADDRESS=
VITE_FACTORY_ADDRESS=
VITE_TREASURY_ADDRESS=

# ─── EVM chain (wagmi + RainbowKit) ────────────────────────────────────
# Set per repo:
#   polygon-repo → Polygon Amoy (80002)
#   arc-repo     → Arc testnet (chain id TBD from Circle docs)
VITE_CHAIN_ID=80002
VITE_CHAIN_NAME=Polygon Amoy
VITE_CHAIN_NATIVE_SYMBOL=POL
VITE_CHAIN_NATIVE_DECIMALS=18
VITE_RPC_URL=https://rpc-amoy.polygon.technology
VITE_CHAIN_EXPLORER_URL=https://amoy.polygonscan.com

# ─── WalletConnect ─────────────────────────────────────────────────────
# Free at https://cloud.reown.com — needed for WalletConnect / mobile
# wallet flows. MetaMask / injected connectors work without an id.
VITE_WALLETCONNECT_PROJECT_ID=

# ─── Sentry (optional) ─────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=devnet-beta
